# ============================================================================
#  Astroventure Nights — environment variables
#  Copy this file to ".env.local" and fill in your values.
# ============================================================================

# --- Registration form email delivery (app/api/register/route.ts) -----------
# Uses Resend (https://resend.com) by default. Create a free account, add &
# verify a domain, then create an API key.
RESEND_API_KEY=

# The recipients who receive each booking enquiry.
# Recipient 1 is set. Add recipient 2 whenever you have it.
NOTIFY_EMAIL_1=astriseducation@gmail.com
NOTIFY_EMAIL_2=

# The "From" address. Must be on a domain you've verified in Resend.
# During testing you can use: Astroventure Nights <onboarding@resend.dev>
NOTIFY_FROM=Astroventure Nights <bookings@yourdomain.com>

# Optional: your production URL (used for absolute OG/canonical links).
# Also update SITE_URL in app/astroventure-nights/layout.tsx & page files.
# NEXT_PUBLIC_SITE_URL=https://astrisspace.com

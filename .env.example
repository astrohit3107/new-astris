# ============================================================================
#  Astroventure Nights — environment variables
#  Copy this file to ".env.local" (local) or add these in Vercel → Settings →
#  Environment Variables (production). ALL OF THESE ARE OPTIONAL.
# ============================================================================

# --- Email delivery ---------------------------------------------------------
# Booking enquiries work OUT OF THE BOX via FormSubmit (no key needed) and are
# delivered to the two addresses below.
#
# ⚠️ ONE-TIME STEP: the first time the form is submitted, FormSubmit emails an
# activation link to NOTIFY_EMAIL_1 (astriseducation@gmail.com). Open that
# email and click the link once — after that every enquiry arrives automatically
# (with NOTIFY_EMAIL_2 CC'd).
NOTIFY_EMAIL_1=astriseducation@gmail.com
NOTIFY_EMAIL_2=eeshumtravels@gmail.com

# --- Optional upgrades (set either to override FormSubmit) -------------------
# Web3Forms — free, no domain to verify. Key from https://web3forms.com
WEB3FORMS_ACCESS_KEY=

# Resend — needs a verified sending domain. https://resend.com
RESEND_API_KEY=
# Leave blank to use Resend's shared onboarding@resend.dev sender.
NOTIFY_FROM=

# Optional: your production URL (used for absolute OG/canonical links).
# Also update SITE_URL in app/astroventure-nights/layout.tsx & page files.
# NEXT_PUBLIC_SITE_URL=https://astrisspace.com

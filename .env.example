# ============================================================================
#  Astroventure Nights — environment variables
#  Copy this file to ".env.local" (local) or add these in Vercel → Settings →
#  Environment Variables (production). Pick ONE email option below.
# ============================================================================

# --- Where booking enquiries are emailed ------------------------------------
# Both inboxes receive every "Reserve Your Spot" submission.
NOTIFY_EMAIL_1=astriseducation@gmail.com
NOTIFY_EMAIL_2=eeshumtravels@gmail.com

# ============================================================================
#  OPTION A — Web3Forms  (recommended: easiest, no domain to verify)
# ----------------------------------------------------------------------------
#  1. Go to https://web3forms.com and enter astriseducation@gmail.com
#  2. Copy the access key they email you
#  3. Paste it here (and add eeshumtravels@gmail.com as a second recipient
#     from the Web3Forms dashboard)
# ============================================================================
WEB3FORMS_ACCESS_KEY=

# ============================================================================
#  OPTION B — Resend  (https://resend.com)
# ----------------------------------------------------------------------------
#  Use this if you have / will verify a sending domain.
# ============================================================================
RESEND_API_KEY=
# "From" address. Leave blank to use Resend's shared onboarding@resend.dev
# (note: until you verify your own domain, that sender only delivers to the
# email you registered your Resend account with).
NOTIFY_FROM=

# Optional: your production URL (used for absolute OG/canonical links).
# Also update SITE_URL in app/astroventure-nights/layout.tsx & page files.
# NEXT_PUBLIC_SITE_URL=https://astrisspace.com
